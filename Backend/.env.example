# --- Required secrets ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Vector store (must match Pipeline/ingest.py) ---
CHROMA_DIR=../Pipeline/chroma_db
COLLECTION_NAME=vaughn_personal_docs
EMBEDDING_MODEL=text-embedding-3-small

# --- LLM ---
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=1024
TEMPERATURE=0.2

# --- Retrieval ---
TOP_K=10
# Optional relevance-score floor in [0,1]. Leave blank to keep all top_k results.
# Set to e.g. 0.65 to drop weakly-matching chunks before they reach Claude.
# MIN_SIMILARITY_SCORE=0.65
ENABLE_QUERY_EXPANSION=true

# --- Hybrid retrieval (BM25 + Claude rerank) ---
# Default retriever for /api/chat when no ?use_bm25=... query param is given.
# false = vector-only (cheap), true = BM25 + rerank (one extra LLM call per request).
ENABLE_BM25=false
BM25_CANDIDATES=25
RERANK_TOP_K=8
# Optional: override the model used for reranking. Defaults to CLAUDE_MODEL.
# RERANK_MODEL=claude-haiku-4-20250514

# --- HTTP / CORS (JSON list) ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Telegram notifications (optional) ---
# Both must be set or notifications no-op silently. Get a token from
# @BotFather and your chat id from @userinfobot in Telegram.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-token-here
# TELEGRAM_CHAT_ID=123456789
ENABLE_TELEGRAM_NOTIFICATIONS=true
# Per-IP+path throttle for /api/visit notifications (seconds). 0 = off.
VISIT_THROTTLE_SECONDS=3600
